{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.ts",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist/public"
      }
    }
  ],
  "routes": [
    {
      "src": "^/favicon\\.webp$",
      "dest": "/favicon.webp"
    },
    {
      "src": "^/manifest\\.json$",
      "dest": "/manifest.json",
      "headers": {
        "Content-Type": "application/manifest+json",
        "Cache-Control": "public, max-age=3600"
      }
    },
    {
      "src": "^/sw\\.js$",
      "dest": "/sw.js",
      "headers": {
        "Content-Type": "application/javascript",
        "Service-Worker-Allowed": "/",
        "Cache-Control": "no-cache"
      }
    },
    {
      "src": "^/service-worker\\.js$",
      "dest": "/service-worker.js",
      "headers": {
        "Content-Type": "application/javascript",
        "Service-Worker-Allowed": "/",
        "Cache-Control": "no-cache"
      }
    },
    {
      "src": "^/registerSW\\.js$",
      "dest": "/registerSW.js",
      "headers": {
        "Content-Type": "application/javascript",
        "Cache-Control": "no-cache"
      }
    },
    {
      "src": "^/assets/(.*\\.js)$",
      "dest": "/assets/$1",
      "headers": {
        "Content-Type": "application/javascript",
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "^/assets/(.*\\.(css|woff2|woff|ttf))$",
      "dest": "/assets/$1",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "^/([\\w\\-\\.]+\\.js)$",
      "dest": "/$1",
      "headers": {
        "Content-Type": "application/javascript",
        "Cache-Control": "public, max-age=31536000"
      }
    },
    {
      "src": "^/icon-192\\.webp$",
      "dest": "/icon-192.webp"
    },
    {
      "src": "^/icon-512\\.webp$",
      "dest": "/icon-512.webp"
    },
    {
      "src": "^/apple-touch-icon\\.webp$",
      "dest": "/apple-touch-icon.webp"
    },
    {
      "src": "^/api/auth$",
      "dest": "api/auth.ts"
    },
    {
      "src": "^/api/restaurants$",
      "dest": "api/restaurants.ts"
    },
    {
      "src": "^/api/admin/restaurants$",
      "dest": "api/admin/restaurants.ts"
    },
    {
      "src": "^/api/admin/menu$",
      "dest": "api/admin/menu.ts"
    },
    {
      "src": "^/api/(.*)",
      "dest": "api/index.ts"
    },
    {
      "src": "^/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
